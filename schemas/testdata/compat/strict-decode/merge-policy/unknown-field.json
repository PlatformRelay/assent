{
  "apiVersion": "assent.dev/v1alpha1",
  "kind": "MergePolicy",
  "metadata": {"name": "topic-safety"},
  "spec": {
    "rules": [
      {
        "name": "no-topic-deletion",
        "match": {"fileEvents": {"paths": ["topics/**"], "kinds": ["delete", "rename"]}},
        "effect": "block",
        "bogusField": "x"
      }
    ]
  }
}
