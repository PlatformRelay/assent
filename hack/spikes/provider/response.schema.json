{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assent.dev/schemas/provider/v1alpha1/response.schema.json",
  "title": "FactResponse",
  "description": "Versioned response envelope returned by a fact provider (HTTP body or exec stdout). Every requested output appears exactly once with an explicit state — never a silently absent key (ADR-0017 §6).",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "queryId", "facts"],
  "properties": {
    "apiVersion": { "const": "provider.assent.dev/v1alpha1" },
    "kind": { "const": "FactResponse" },
    "queryId": {
      "type": "string",
      "minLength": 1,
      "description": "Echo of FactQuery.queryId."
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fact" },
      "description": "One entry per requested output name."
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "declaration", "state", "subject", "observedAt"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "declaration": { "$ref": "#/$defs/declaration" },
        "state": {
          "enum": ["resolved", "unavailable", "invalid", "expired"],
          "description": "Distinct machine states; controlling facts treat everything but resolved as fail-closed."
        },
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": { "enum": ["user", "group", "entry", "repo"] },
            "id": { "type": "string", "minLength": 1 }
          }
        },
        "observedAt": { "type": "string", "format": "date-time" },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "observedAt + declaration.maxAge; required when state is resolved."
        },
        "value": {
          "description": "Present only when state is resolved; shape governed by declaration.type/cardinality."
        },
        "reason": {
          "type": "string",
          "description": "Operator-readable cause for a non-resolved state; never raw provider internals."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "resolved" } } },
          "then": { "required": ["value", "expiresAt"] },
          "else": { "not": { "required": ["value"] } }
        }
      ]
    },
    "declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "cardinality", "subject", "sensitive", "maxAge"],
      "description": "The typed output declaration this fact was produced under (echoed so the host can verify it against config).",
      "properties": {
        "type": { "enum": ["boolean", "string", "integer", "principal"] },
        "cardinality": { "enum": ["single", "set"] },
        "subject": { "enum": ["user", "group", "entry", "repo"] },
        "sensitive": { "type": "boolean" },
        "maxAge": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "description": "Go-style duration; arming precondition per ADR-0017 §4, not advisory."
        }
      }
    }
  }
}
