{
  "apiVersion": "assent.dev/v1alpha1",
  "kind": "MergePolicy",
  "metadata": { "name": "topic-safety" },
  "spec": {
    "entries": {
      "topic-registry": {
        "mode": "document",
        "root": "",
        "identity": { "pointer": "/metadata/name" }
      }
    },
    "rules": [
      {
        "name": "topic-owner-must-approve",
        "match": { "files": { "paths": ["topics/prod/**.yaml"] } },
        "prove": {
          "obligation": "ownership",
          "when": "facts.owner.team.state == 'resolved'"
        },
        "onFailure": { "effect": "require-review", "code": "ownership-approval-missing" }
      },
      {
        "name": "partitions-must-not-shrink",
        "match": { "valueChanges": { "pointers": ["/partitions"], "kinds": ["modify"] } },
        "prove": {
          "obligation": "non-destructive",
          "when": "input.new >= input.old"
        },
        "onFailure": { "effect": "block", "code": "partition-count-shrunk" }
      }
    ]
  }
}
